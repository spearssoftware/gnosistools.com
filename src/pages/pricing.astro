---
import Landing from '../layouts/Landing.astro';
---

<Landing title="Gnosis - Pricing">
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="logo">Gnosis</a>
      <div class="nav-links">
        <a href="/getting-started/">Docs</a>
        <a href="/pricing/">Pricing</a>
        <a href="/signup/" class="btn-nav">Get API Key</a>
      </div>
    </div>
  </nav>

  <section class="pricing">
    <div class="container">
      <h1>Simple pricing</h1>
      <p class="pricing-subtitle">Start free. Upgrade when you need more.</p>

      <div class="pricing-grid">
        <div class="pricing-card">
          <h2>Free</h2>
          <div class="price">$0<span>/month</span></div>
          <ul>
            <li>1,000 requests/day</li>
            <li>All REST endpoints</li>
            <li>Full-text search</li>
            <li>Community support</li>
          </ul>
          <a href="/signup/" class="btn-primary">Get Started Free</a>
        </div>

        <div class="pricing-card featured">
          <h2>Need more?</h2>
          <p class="pro-desc">If you're interested in higher rate limits, semantic search, or priority support, get in touch and we'll work something out.</p>
        </div>
      </div>

      <div class="contact-section">
        <h2>Contact us</h2>
        <form id="contact-form" class="contact-form">
          <input type="hidden" name="subject" value="gnosis-pricing">
          <div class="form-group">
            <label for="contact-name">Name</label>
            <input type="text" id="contact-name" name="name" required />
          </div>
          <div class="form-group">
            <label for="contact-email">Email</label>
            <input type="email" id="contact-email" name="email" required />
          </div>
          <div class="form-group">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="message" rows="4" required placeholder="Tell us about your project and what you need..."></textarea>
          </div>
          <div class="cf-turnstile" data-sitekey="0x4AAAAAACvCAsyh8OPexFCf"></div>
          <button type="submit" class="btn-primary">Send Message</button>
          <p id="form-status" class="form-status"></p>
        </form>
      </div>

      <p class="open-source-note">
        The raw dataset is always free and open source under CC-BY-SA 4.0.
        <a href="https://github.com/kevswanson/gnosis">Download from GitHub.</a>
      </p>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 <a href="https://spearssoftware.com">Spears Software</a> &middot; <a href="/getting-started/">Docs</a> &middot; <a href="/pricing/">Pricing</a> &middot; <a href="https://github.com/kevswanson/gnosis">GitHub</a></p>
    </div>
  </footer>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    document.getElementById('contact-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = this.querySelector('button[type="submit"]');
      var status = document.getElementById('form-status');
      var turnstileResponse = turnstile.getResponse();

      if (!turnstileResponse) {
        status.textContent = 'Please complete the verification.';
        status.className = 'form-status error';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Sending...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        var res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: this.elements.name.value,
            email: this.elements.email.value,
            message: this.elements.message.value,
            subject: this.elements.subject.value,
            turnstileToken: turnstileResponse
          })
        });
        var data = await res.json();
        if (data.success) {
          this.innerHTML = '<div class="form-success"><p>Message sent! We\'ll get back to you soon.</p></div>';
          return;
        } else {
          status.textContent = data.error || 'Something went wrong. Please try again.';
          status.className = 'form-status error';
        }
      } catch {
        status.textContent = 'Something went wrong. Please try again.';
        status.className = 'form-status error';
      }

      btn.disabled = false;
      btn.textContent = 'Send Message';
    });
  </script>
</Landing>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #1e293b;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 20px;
    font-weight: 700;
    color: #e2e8f0;
  }

  .nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .nav-links a {
    color: #94a3b8;
    font-size: 14px;
    font-weight: 500;
  }

  .btn-nav {
    background: #6366f1;
    color: #fff !important;
    padding: 8px 16px;
    border-radius: 8px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .pricing {
    padding: 140px 0 80px;
    text-align: center;
  }

  .pricing h1 {
    font-size: 40px;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .pricing-subtitle {
    color: #94a3b8;
    font-size: 18px;
    margin-bottom: 48px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 720px;
    margin: 0 auto 48px;
  }

  .pricing-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 16px;
    padding: 36px;
    text-align: left;
  }

  .pricing-card.featured {
    border-color: #6366f1;
  }

  .pricing-card h2 {
    font-size: 24px;
    margin-bottom: 12px;
  }

  .price {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 24px;
    color: #818cf8;
  }

  .price span {
    font-size: 16px;
    font-weight: 400;
    color: #64748b;
  }

  .pricing-card ul {
    list-style: none;
    margin-bottom: 28px;
  }

  .pricing-card li {
    padding: 8px 0;
    color: #94a3b8;
    border-bottom: 1px solid #334155;
    font-size: 15px;
  }

  .btn-primary {
    display: inline-block;
    background: #6366f1;
    color: #fff;
    padding: 12px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 16px;
    width: 100%;
    text-align: center;
  }

  .btn-primary:hover {
    background: #818cf8;
    color: #fff;
  }

  .pro-desc {
    color: #94a3b8;
    font-size: 15px;
    line-height: 1.7;
    margin-top: 8px;
  }

  .contact-section {
    max-width: 480px;
    margin: 0 auto 48px;
    text-align: left;
  }

  .contact-section h2 {
    font-size: 24px;
    margin-bottom: 24px;
    text-align: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 500;
    color: #94a3b8;
  }

  .form-group input,
  .form-group textarea {
    padding: 12px 16px;
    font-size: 15px;
    border: 2px solid #334155;
    border-radius: 10px;
    background: #1e293b;
    color: #e2e8f0;
    outline: none;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #6366f1;
  }

  .form-status {
    font-size: 14px;
    text-align: center;
  }

  .form-status.error {
    color: #ef4444;
  }

  .form-success {
    text-align: center;
    padding: 24px;
    color: #10b981;
    font-weight: 500;
  }

  .open-source-note {
    color: #64748b;
    font-size: 14px;
  }

  .footer {
    padding: 32px 0;
    border-top: 1px solid #1e293b;
    text-align: center;
    font-size: 14px;
    color: #64748b;
  }

  @media (max-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
