---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/Nav.astro';
import { BibleExplorer } from '../components/BibleExplorer';
---

<Landing title="Gnosis - Explore the Bible">
  <Nav />

  <section class="hero">
    <div class="container">
      <h1>Explore the Bible</h1>
      <p class="subtitle">
        Search for any biblical figure. See their family tree, timeline, and connections across scripture.
      </p>
    </div>
  </section>

  <section class="explorer">
    <BibleExplorer client:load />
  </section>

  <section class="stats">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-number">3,000+</span>
        <span class="stat-label">People</span>
      </div>
      <div class="stat">
        <span class="stat-number">1,200+</span>
        <span class="stat-label">Places</span>
      </div>
      <div class="stat">
        <span class="stat-number">450+</span>
        <span class="stat-label">Events</span>
      </div>
      <div class="stat">
        <span class="stat-number">29,000+</span>
        <span class="stat-label">Cross-References</span>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="container">
      <h2>What is Gnosis?</h2>
      <p>
        Gnosis is a biblical knowledge graph that connects people, places, events, genealogies, Strong's concordance,
        and Hebrew/Greek morphology into a single, queryable dataset. The data is open source under CC-BY-SA 4.0, and
        available as a REST API for developers.
      </p>
      <div class="about-cta">
        <a href="/developers/" class="btn-primary">For Developers</a>
        <a href="https://github.com/spearssoftware/gnosis" class="btn-secondary">View on GitHub</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 <a href="https://spearssoftware.com">Spears Software</a> &middot; <a href="/getting-started/">Docs</a> &middot; <a href="/developers/">Developers</a> &middot; <a href="https://github.com/spearssoftware/gnosis">GitHub</a></p>
    </div>
  </footer>
</Landing>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero {
    padding: 120px 0 40px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    background: linear-gradient(135deg, #e2e8f0, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 18px;
    color: #94a3b8;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .explorer {
    padding: 0 0 40px;
  }

  .stats {
    padding: 60px 0;
    border-top: 1px solid #1e293b;
    border-bottom: 1px solid #1e293b;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 36px;
    font-weight: 800;
    color: #818cf8;
  }

  .stat-label {
    font-size: 14px;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .about {
    padding: 80px 0;
    text-align: center;
  }

  .about h2 {
    font-size: 32px;
    margin-bottom: 16px;
  }

  .about p {
    font-size: 16px;
    color: #94a3b8;
    max-width: 640px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .about-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  .btn-primary {
    background: #6366f1;
    color: #fff;
    padding: 12px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 16px;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: #818cf8;
    color: #fff;
  }

  .btn-secondary {
    border: 1px solid #334155;
    color: #e2e8f0;
    padding: 12px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 16px;
    transition: border-color 0.2s;
  }

  .btn-secondary:hover {
    border-color: #6366f1;
    color: #e2e8f0;
  }

  .footer {
    padding: 32px 0;
    border-top: 1px solid #1e293b;
    text-align: center;
    font-size: 14px;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
